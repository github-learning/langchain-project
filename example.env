# Copy this file to ".env" (which is gitignored) and fill in your values.
#
# Option A (recommended): OpenAI-compatible naming
OPENAI_API_KEY=sk-your-key
# Optional: only set if you use a non-default OpenAI-compatible endpoint (e.g. Qwen/DeepSeek/etc)
OPENAI_BASE_URL=https://api.openai.com/v1
MODEL_NAME=qwen-coder-turbo
#
# Option B (legacy naming): also supported by the scripts in this repo
# API_KEY=sk-your-key
# BASE_URL=https://api.openai.com/v1
# MODEL_NAME=qwen-coder-turbo

